<div class="row justify-content-center">
  <div class="col-4">
    <h1 class: 'mb-3'>Inform new found Pet:</h1>
    <%= simple_form_for @pet do |f| %>
      <%= f.input :species, collection: ["Dog", "Cat", "Fish", "Horse", "Turtle"] %>
      <%= f.input :description %>
      <%= f.input :address %>
      <%= f.input :found_at %>
      <div class="d-grid">
        <%= f.submit "Create Pet", class: 'btn btn-success' %>
      </div>
    <% end %>
  </div>
</div>
